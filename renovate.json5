{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>yaizuuuu/my-renovate-config"],
  "regexManagers": [
    {
      "fileMatch": ["^install\\.sh$"],
      "matchStrings": [
        "SAFE_CHAIN_VER=\"(?<currentValue>.*)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "AikidoSec/safe-chain"
    },
  ]
}
