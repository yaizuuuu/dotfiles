{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "medium",
  "env": {
    "AWS_VAULT_KEYCHAIN_NAME": "login"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME\"/.claude/notify.sh \"Notification\" \"入力待ちです\"",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME\"/.claude/notify.sh \"Error\" \"エラーが発生しました\"",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME\"/.claude/notify.sh \"Stop\" \"作業が完了しました\"",
            "type": "command"
          }
        ]
      }
    ]
  },
  "language": "Japanese",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Skills",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git worktree:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(gh pr:*)"
    ],
    "deny": [
      "Read(**/credentials.json)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.key)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(**/settings.json)",
      "Write(**/settings.local.json)",
      "Bash(sudo:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(rm -rf .git)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)"
    ]
  },
  "voiceEnabled": true
}