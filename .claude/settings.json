{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "medium",
  "env": {
    "AWS_VAULT_KEYCHAIN_NAME": "login"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME\"/.claude/notify.sh \"Notification\" \"入力待ちです\"",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME\"/.claude/notify.sh \"Error\" \"エラーが発生しました\"",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME\"/.claude/notify.sh \"Stop\" \"作業が完了しました\"",
            "type": "command"
          }
        ]
      }
    ]
  },
  "language": "Japanese",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Skills",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git worktree:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git switch:*)",
      "Bash(gh pr:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(**/settings.json)",
      "Write(**/settings.local.json)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "mcp__supabase__execute_sql"
    ]
  },
  "voiceEnabled": true
}